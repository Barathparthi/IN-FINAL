# Copy this file to .env.deploy.local and fill real values.
# Use a unique name to create a brand-new stack and resources.
STACK_NAME=Ec2DeploymentStack
INSTANCE_TYPE=t3.micro
KEY_NAME=coding-platform-External
REPO_URL=https://github.com/Bandarusuryapranay/1234.git
REPO_BRANCH=main

# Backend runtime env mapped into CDK parameters
# Leave DATABASE_URL empty to use local postgres inside docker-compose.
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=http://localhost:4000
ADMIN_IP_CIDR=0.0.0.0/0

# AI provider keys
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_STT_MODEL=whisper-large-v3-turbo
JUDGE0_API_URL=http://judge0-server:2358

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional app-level redis URL
REDIS_URL=redis://redis:6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Azure Graph mail settings required by backend env schema
AZURE_TENANT_ID=placeholder-tenant-id
AZURE_CLIENT_ID=placeholder-client-id
AZURE_CLIENT_SECRET=placeholder-client-secret
GRAPH_SENDER_EMAIL=noreply@example.com
