# Copy this file to .env.vm and fill values before running 02_deploy_app.sh.
# Example VM IP: PUBLIC_BASE_URL=http://192.168.56.10
PUBLIC_BASE_URL=http://192.168.56.10
VITE_APP_NAME=Indium AI

# Core runtime
NODE_ENV=production
PORT=4000
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional fixed secrets. If left blank, deploy script generates secure values.
POSTGRES_PASSWORD=
JWT_SECRET=
JWT_REFRESH_SECRET=

# AI provider keys. Set at least one; OPENAI_API_KEY defaults to GROQ_API_KEY.
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-large-v3-turbo

# Judge0
JUDGE0_API_KEY=
JUDGE0_MEMORY_LIMIT_DEFAULT_KB=512000
JUDGE0_MEMORY_LIMIT_JS_KB=640000
JUDGE0_MEMORY_LIMIT_JAVA_KB=2097152

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Azure Graph placeholders required by backend env schema in some flows
AZURE_TENANT_ID=placeholder-tenant-id
AZURE_CLIENT_ID=placeholder-client-id
AZURE_CLIENT_SECRET=placeholder-client-secret
GRAPH_SENDER_EMAIL=noreply@example.com

# Optional overrides. If empty, deploy script uses PUBLIC_BASE_URL.
CLIENT_URL=
FRONTEND_URL=
BACKEND_URL=

# Optional
REDIS_URL=redis://redis:6379
# Leave empty to use local postgres inside Docker Compose.
DATABASE_URL=
