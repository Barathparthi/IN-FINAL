# Core runtime
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgressuryapr1825N@db.vvilsmohorhymcnbjsoe.supabase.co:5432/postgres

# JWT
JWT_SECRET=replace_with_a_minimum_32_char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_second_minimum_32_char_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS and app URLs
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
CORS_ALLOW_ALL=false
TRUST_PROXY=1
JSON_LIMIT=10mb
ENABLE_API_DOCS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
STRIKE_RATE_LIMIT_WINDOW_MS=60000
STRIKE_RATE_LIMIT_MAX=60

# AI provider
# OPENAI_API_KEY can be your OpenAI key or Groq key when using OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=replace_with_provider_api_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-large-v3-turbo

# Judge0
JUDGE0_API_URL=http://localhost:2358
JUDGE0_API_KEY=

# Email and Azure
AZURE_TENANT_ID=placeholder-tenant-id
AZURE_CLIENT_ID=placeholder-client-id
AZURE_CLIENT_SECRET=placeholder-client-secret
GRAPH_SENDER_EMAIL=noreply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
