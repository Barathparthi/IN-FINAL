# ----------------------------
# Core runtime
# ----------------------------
NODE_ENV=production
PORT=4000

# If you want external DB, set DATABASE_URL directly and ignore POSTGRES_* below.
# Example external:
# DATABASE_URL=postgresql://user:password@your-db-host:5432/indium_db?sslmode=require

# Local VM Postgres fallback (used by compose if DATABASE_URL is empty)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me_strong_password
POSTGRES_DB=indium_db
DATABASE_URL=

# ----------------------------
# JWT and auth
# ----------------------------
JWT_SECRET=replace_with_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_string_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------
# URLs and CORS
# ----------------------------
CLIENT_URL=http://YOUR_VM_IP_OR_DOMAIN
FRONTEND_URL=http://YOUR_VM_IP_OR_DOMAIN
BACKEND_URL=http://YOUR_VM_IP_OR_DOMAIN
CORS_ALLOW_ALL=false
TRUST_PROXY=1
JSON_LIMIT=10mb
ENABLE_API_DOCS=false

# ----------------------------
# Rate limits
# ----------------------------
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
STRIKE_RATE_LIMIT_WINDOW_MS=60000
STRIKE_RATE_LIMIT_MAX=60

# ----------------------------
# AI provider (Groq through OpenAI SDK style)
# ----------------------------
OPENAI_API_KEY=replace_with_provider_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-large-v3-turbo

# ----------------------------
# Judge0
# ----------------------------
JUDGE0_API_URL=http://judge0-server:2358
JUDGE0_API_KEY=
JUDGE0_HOST_PORT=2358

# Judge0 internal DB
JUDGE0_DB_USER=postgres
JUDGE0_DB_PASSWORD=replace_me_judge0_password
JUDGE0_DB_NAME=judge0

# ----------------------------
# Redis
# ----------------------------
REDIS_URL=redis://redis:6379

# ----------------------------
# Email and Azure
# ----------------------------
AZURE_TENANT_ID=placeholder-tenant-id
AZURE_CLIENT_ID=placeholder-client-id
AZURE_CLIENT_SECRET=placeholder-client-secret
GRAPH_SENDER_EMAIL=noreply@example.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ----------------------------
# Cloudinary
# ----------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----------------------------
# Optional image tags and host ports
# ----------------------------
BACKEND_IMAGE=indium-backend:1.0.0
FRONTEND_IMAGE=indium-frontend:1.0.0
BACKEND_HOST_PORT=4000
FRONTEND_HOST_PORT=8080
